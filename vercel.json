{
  "version": 2,
  "builds": [
    {
      "src": "dist/index.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "dist/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/dist/index.cjs" },
    { "src": "/robots.txt", "dest": "/dist/public/robots.txt" },
    { "src": "/sitemap.xml", "dest": "/dist/public/sitemap.xml" },
    { "src": "/llms.txt", "dest": "/dist/public/llms.txt" },
    { "src": "/assets/(.*)", "dest": "/dist/public/assets/$1" },
    { "src": "/(.*)", "dest": "/dist/public/index.html" }
  ]
}
